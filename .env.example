# Heirloom — Arc testnet deployment config.
# Copy to `.env` and fill in. `.env` is gitignored: NEVER commit real keys.
# UNAUDITED TESTNET CODE — testnet keys only, never a mainnet key.

# --- Chain -----------------------------------------------------------------
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Arc testnet chain id: 5042002

# --- Deployer --------------------------------------------------------------
# Testnet key ONLY. Read from the environment, never written to disk by the
# scripts, never logged.
PRIVATE_KEY=

# --- Vault owner and asset -------------------------------------------------
HEIRLOOM_OWNER=
# Arc USDC. Must expose 6 decimals; the deploy script asserts this and aborts
# otherwise, because every cap below is denominated in 6dp.
HEIRLOOM_USDC=

# --- Cascading heirs, in priority order ------------------------------------
# Tier 0: the owner's own cold backup wallet. Key loss becomes self-recovery.
HEIRLOOM_HEIR_COLD_BACKUP=
# Tier 1: spouse or family. Death becomes inheritance.
HEIRLOOM_HEIR_FAMILY=
# Tier 2: charity or DAO. The terminal sink -- never expires, so funds can
# never dead-end (invariant 6).
HEIRLOOM_HEIR_CHARITY=

# --- Recovery guardians ----------------------------------------------------
# Comma-separated, no spaces. M-of-N.
HEIRLOOM_GUARDIANS=
HEIRLOOM_GUARDIAN_THRESHOLD=2

# --- Care mode (all amounts 6dp: 500000000 == $500.00) ----------------------
HEIRLOOM_CARE_GUARDIAN=
HEIRLOOM_CARE_MONTHLY_CAP=500000000
HEIRLOOM_CARE_BILLS_CAP=300000000
HEIRLOOM_CARE_MEDICAL_CAP=400000000

# Approved care destinations, comma-separated, no spaces. Care mode can pay
# THESE ADDRESSES AND NOBODY ELSE under the matching category -- this is what
# makes a category enforceable rather than a label the guardian asserts.
# Changing them later goes through the 7-day config timelock.
HEIRLOOM_CARE_BILLS_PAYEES=
HEIRLOOM_CARE_MEDICAL_PAYEES=
