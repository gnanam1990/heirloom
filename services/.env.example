# Heirloom off-chain services — configuration.
# Copy to services/.env (gitignored) and fill in. TESTNET ONLY.
# Every credentialed feature stays DISABLED until its vars are present; nothing
# here falls back to a stub or a fake success.

# --- Chain (no credentials needed; these paths always work) ----------------
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Comma-separated. Defaults to the deployed pair from docs/addresses.md.
HEIRLOOM_VAULTS=0xaef39a00cdd1d9b240bde4e08f7b6f9915a386e8,0x12dbb68F3c68BD47BF9799db7112f03ac37f6042

PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

INDEXER_POLL_MS=5000
INDEXER_PAGE_SIZE=2000
# Block of the first production deployment; earlier blocks hold nothing of ours.
INDEXER_START_BLOCK=52719229

# --- Claim links (self-provisioned) ----------------------------------------
# HMAC key for signing heir claim links. Generate your own:
#   openssl rand -hex 32
# Not a third-party credential — you create this.
CLAIM_LINK_SECRET=<64 hex chars>

# --- Telegram /alive bot ---------------------------------------------------
# From @BotFather on Telegram: /newbot, then copy the token.
# The bot NEVER holds an owner key; it returns a transaction for the owner to
# sign in their own wallet.
TELEGRAM_BOT_TOKEN=<123456:ABC-DEF...>

# --- Circle Programmable Wallets (heir onboarding) -------------------------
# console.circle.com -> Developer Controlled Wallets -> TESTNET API key.
CIRCLE_API_KEY=<testnet api key>
# console.circle.com -> register an entity secret, store the ciphertext.
CIRCLE_ENTITY_SECRET=<entity secret ciphertext>

# --- Email delivery for claim links ----------------------------------------
SMTP_HOST=<smtp host>
SMTP_PORT=587
SMTP_USER=<smtp user>
SMTP_PASS=<smtp password>
SMTP_FROM=heirloom@example.invalid
